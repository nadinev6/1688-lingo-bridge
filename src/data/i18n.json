{
  "$schema": "https://lingo.dev/schema/i18n.json",
  "version": "1.11",
  "locale": {
    "source": "zh-CN",
    "targets": ["en"]
  },
  "provider": {
    "id": "lingo.dev",
    "prompt": "You are a specialist in international B2B wholesale. Translate 1688 product data into professional English for international buyers. Maintain technical accuracy for GaN electronics, Mulberry silk textiles, and Energy Storage systems."
  },
  "tag_translations": {
    "_comment": "Static lookup tables for service tags and badges - see src/data/translations.ts for implementation",
    "service_tags": {
      "退货包运费": "Free return shipping",
      "先采后付": "Buy now, pay later",
      "7天无理由": "7-day no-reason returns",
      "24小时发货": "Ships within 24h",
      "48小时发货": "Ships within 48h",
      "现货": "In stock",
      "包邮": "Free shipping"
    },
    "badges": {
      "运费险": "Shipping insurance",
      "深度验商": "Verified supplier",
      "深度验厂": "Verified factory",
      "金牌供应商": "Gold medal supplier",
      "超级工厂": "Super factory"
    },
    "dynamic_patterns": [
      { "pattern": "^回头率(\\d+%?)$", "template": "Repurchase rate: $1" },
      { "pattern": "^(\\d+)天无理由$", "template": "$1-day no-reason returns" },
      { "pattern": "^(\\d+)小时发货$", "template": "Ships within $1h" }
    ]
  },
  "glossary": [
    { "src": "氮化镓", "tgt": "Gallium Nitride (GaN)" },
    { "src": "桑蚕丝", "tgt": "Mulberry Silk" },
    { "src": "户外电源", "tgt": "Portable Power Station" },
    { "src": "储能电源", "tgt": "Energy Storage Power" },
    { "src": "起订量", "tgt": "MOQ" },
    { "src": "包邮", "tgt": "Free Delivery (Equivalent)" }
  ],
  "negative_keywords": {
    "electronics": ["模具", "餐垫", "硅胶", "烘焙", "厨房", "蛋糕", "餐具"],
    "textiles": ["电子", "电池", "充电", "电源", "储能"],
    "power": ["模具", "餐垫", "硅胶", "烘焙", "厨房", "蛋糕", "餐具", "纺织", "服装"]
  },
  "synonyms": {
    "户外电源": ["便携式储能", "露营电源", "移动电源"],
    "储能电源": ["储能", "蓄电", "备用电源"],
    "氮化镓": ["GaN充电器", "GaN", "氮化镓充电器"],
    "桑蚕丝": ["真丝", "丝绸", "蚕丝"]
  },
  "category_hints": {
    "consumer electronics": "消费电子",
    "camping gear": "露营装备",
    "high-capacity batteries": "大容量电池",
    "portable power": "便携电源",
    "energy storage": "储能"
  },
  "suspicious_terms": {
    "electronics": ["二手", "配件", "维修", "拆机", "翻新"],
    "textiles": ["次品", "尾货", "库存", "瑕疵"],
    "general": ["样品", "试用"]
  },
  "category_mappings": {
    "consumer electronics": ["消费电子", "数码", "电子产品", "电子"],
    "camping gear": ["露营装备", "户外用品", "户外"],
    "batteries": ["电池", "电源", "储能"],
    "high-capacity batteries": ["电池", "电源", "储能"],
    "power": ["电源", "储能", "充电", "电池"],
    "textiles": ["纺织品", "面料", "家纺", "丝绸"]
  },
  "vision_prompts": {
    "default": "Does this product image match the buyer's search intent?",
    "electronics": "Does this image show an electronic device or component? Look for circuit boards, screens, charging ports, or electronic housings.",
    "power": "Does this image show a power station, battery, or energy storage device? Look for battery packs, power outlets, LED displays showing capacity, or solar panels.",
    "textiles": "Does this image show a textile product? Look for fabric, pillows, bedding, or clothing items.",
    "silk": "Does this image show silk fabric or silk products? Look for the characteristic sheen, smooth texture, and luxury appearance of silk."
  },
  "vision_categories": {
    "portable power station": {
      "must_have": ["battery", "power outlet", "display", "enclosure"],
      "must_not_have": ["fabric", "food", "kitchen utensils", "molds"]
    },
    "gan charger": {
      "must_have": ["charging port", "plug", "compact design"],
      "must_not_have": ["fabric", "food", "kitchen utensils"]
    },
    "silk pillowcase": {
      "must_have": ["fabric", "pillow shape", "smooth texture"],
      "must_not_have": ["electronics", "plastic", "metal"]
    }
  }
}
