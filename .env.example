# 1688 Lingo Bridge - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Lingo.dev Translation
# ============================================
# Lingo.dev API Key
# Get your API key from: https://lingo.dev/dashboard
LINGODOTDEV_API_KEY=your_lingo_dev_api_key_here

# ============================================
# Vision Validation (GPT-4o-mini)
# ============================================
# OpenAI API Key for image validation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Vision Configuration (optional)
# Enable/disable vision validation (default: true)
VISION_ENABLED=true

# Maximum products to validate per run (default: 10)
# HARD LIMIT: Only top N high-confidence products reach the API
# This protects against rate limits and controls costs
VISION_MAX_PRODUCTS=10

# Model for vision validation (default: gpt-4o-mini)
# Options: gpt-4o-mini (cheaper), gpt-4o (more capable)
VISION_MODEL=gpt-4o-mini

# Timeout for vision API calls in milliseconds (default: 3000)
VISION_TIMEOUT_MS=3000

# Enable/disable vision result caching (default: true)
VISION_CACHE_ENABLED=true
